# 1.16.1 — ruined portal speedrun seed
# Any ruined portal template except giant, as long as it's viable:
#   - no crying obsidian
#   - chest holds enough obsidian to finish + light the portal
# Chest also needs 2+ obsidian and a flint and steel.
version 1.16.1
threads 8
max_results 5

spawn within 10 of origin

dimension overworld {
  ruined_portal within 25 of spawn viable giant false chest item obsidian min 2 chest item flint_and_steel min 1
}
